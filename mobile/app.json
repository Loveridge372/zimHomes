{
  "expo": {
    "name": "Wana Imba",
    "slug": "wana-imba",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "wanaimba",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#11613b"
      }
    },
    "splash": {
      "image": "./assets/wana-imba-background.jpeg",
      "resizeMode": "cover",
      "backgroundColor": "#11613b"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
